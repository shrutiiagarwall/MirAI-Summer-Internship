# MirAI Visual Novel — Environment Variables (TEMPLATE)
# Copy this file to .env and fill in your Gemini API keys.
# ─────────────────────────────────────────────────────────────────────────────
# API KEY ROTATION
# Add up to 5 keys. When KEY_1 hits rate limits, the app auto-retries with
# KEY_2, then KEY_3, etc. — without any manual intervention.
#
# Get free keys at: https://aistudio.google.com/app/apikey
# ─────────────────────────────────────────────────────────────────────────────

GEMINI_API_KEY_1=your_primary_key_here
GEMINI_API_KEY_2=your_second_key_here
GEMINI_API_KEY_3=
GEMINI_API_KEY_4=
GEMINI_API_KEY_5=

# Legacy single-key fallback (used only if GEMINI_API_KEY_1 is empty)
# GEMINI_API_KEY=your_key_here